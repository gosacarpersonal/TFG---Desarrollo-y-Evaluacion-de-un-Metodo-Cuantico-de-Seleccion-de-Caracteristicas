asian="normal" style:font-style-complex="normal" style:text-emphasize="none" style:font-relief="none" style:text-overline-style="none" style:text-overline-color="font-color"/></style:style></office:automatic-styles><office:body><office:spreadsheet><table:calculation-settings table:automatic-find-labels="false" table:use-regular-expressions="false" table:use-wildcards="true"/><table:table table:name="FIGURAS" table:style-name="ta1"><table:table-column table:style-name="co1" table:default-cell-style-name="Default"/><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>FIGURAS Y TABLAS</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell/></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>General</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>No poner capturas de pantalla, si hay que ponerlas poner mucha calidad.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell/></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>Al hacer una gráfica</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Ejes en las gráfica con nombres</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Con leyenda en las gráficas</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Tamaño del texto dentro de la figura ha de ser legible</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Que sea bonita</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>No pongas cosas que no sirven de nada, que sea lo mas limpia posible.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell/></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>Al poner la figura en el codumento</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Aspect-ratio no cambie</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>La resolución de la figura ha de ser correcta (no pixelada)</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Pies de figura descriptivo. En los pies de figura hay que definir cada parte de la figura en detalle.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>La figura ha de estar comentada y referenciada en el texto principal.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell/></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>Tablas</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Intenta poner pocas cifras significativas</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Resalta los valores importantes</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Si puedes, normaliza los valores para facilitar la comparación.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Si es muy grande, intentar hacer una versión en una gráfica para ofrecer los resultados de un vistazo. Las tablas están bien para detalles.</text:p></table:table-cell></table:table-row></table:table><table:table table:name="ESTILO" table:style-name="ta1"><table:table-column table:style-name="co9" table:default-cell-style-name="Default"/><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>ESTILO</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5"/></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p><text:span text:style-name="T1">Importancia</text:span> de que esté bien. Poner mas esfuerzo en estas partes por orden.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>1) resumen, 2) conclusiones, 3) introducción, 4) resultados y 5) lo demás</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5"/></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>Estilo de escritura</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>No hay cosas redundantes. Puede ser redundante en resumen, cuerpo del documento y conclusiones.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>No hay cosas que falta explicar con mas detalle</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>El texto está a nivel formal adecuado</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Se entiende, el texto es claro</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Se conectan las ideas de forma adecuada</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Consistencia de idioma, intenta que siempre sea en el mismo idioma (variables, ejes gráficas…)</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell/></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>Estilo del texto</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce6" office:value-type="string" calcext:value-type="string"><text:p>Hay que numerar las páginas</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce6" office:value-type="string" calcext:value-type="string"><text:p>Encabezado de página y pie de página</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce6" office:value-type="string" calcext:value-type="string"><text:p>Texto justificado</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce6" office:value-type="string" calcext:value-type="string"><text:p>Espacio antes y después de los títulos</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce6"/></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>Cosas formales</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Ortografía. No pueden haber faltas. </text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Intentar no usar acrónimos. Si se usan definirlos la primera vez que aparecen, y si hace mucho que aparecen volverlos a definir.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Formato de los números correcto (tipo de puntuación), solo 3-4 cifras significativas.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p><text:span text:style-name="T2">Intentar no poner links, si se ponen que no estén ocultos en el pdf, i.e. si se imprime el documento ha de poder accederse a </text:span>los links </text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Puntuación: Espacio después de un punto, comillas en formato adecuado…</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>No hacer párrafos muy largos</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell/></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>Sobre las referencias</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce6" office:value-type="string" calcext:value-type="string"><text:p>Meter el DOI en las referencias</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Referencias en el texto, al final de la frase antes del punto o la coma.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p><text:span text:style-name="T2">Referencias e</text:span>n el apartado de referencias: Por lo menos Titulo, autor, revista, año</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Cada idea que se ponga que sea clave necesita una referencia, o una justificación detallada.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell/></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>Estilo de la estructura</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>El resumen contiene los elementos de la estructura del documento: motivación, problema, solución y resultados.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Siempre que pongas un capítulo, sección, subsección tiene que haber algo escrito después. Sobre todo entre el título del capítulo y la primera sección: hay que explicar de que va el capítulo.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell/></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>Fórmulas</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Variables de las fórmulas consistentes en todo el texto</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Las variables de las fór,ulas hay que definirlas justo después o antes de las fórmulas (si no han sido definidas ya).</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Usar un sistema para diferencias escalares de vectores y matrices. Por ejemplo, escalares en minñusculas, vectores en minñusculas en negrita, y matrices en mayúsculas en negrita.</text:p></table:table-cell></table:table-row></table:table><table:table table:name="ESTRUCTURA" table:style-name="ta1"><table:table-column table:style-name="co8" table:default-cell-style-name="Default"/><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>ESTRUCTURA</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell/></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>La estructura es en general</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce6" office:value-type="string" calcext:value-type="string"><text:p>Portada + índice + índice de figuras + índice tablas</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce6" office:value-type="string" calcext:value-type="string"><text:p>Resumen + agradecimientos</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Introducción (motivación + objetivos + descripción del documento) </text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>nudo (descripción del problema, estado del arte (soluciones ya propuestas), propuesta propia: modelos y datos)</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>desenlace (experimentos + resultados)</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>epílogo (conclusiones: son un resumen del documento y de lo que se ha conseguido)</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1" table:number-rows-repeated="2"><table:table-cell/></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>El documento ha de contener</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Descripción del problema</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Descripción y visualización de datos exhaustiva</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Descripción de los modelos</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Descripción matemática del objetivo</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Descripción del modo de optimización del modelo</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell/></table:table-row><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>Cosas</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Poner siempre índice, con numeraión en las páginas.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Si el documento es largo (i.e. &gt;40 páginas) poner lista de figuras y lista de tablas.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Ha de estar bien la numeración del índice</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Hay que buscar una estructura en que las cosas relacionadas estén lo mas cerca posible. </text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>No dejar huecos en blanco</text:p></table:table-cell></table:table-row></table:table><table:table table:name="CONTENIDO" table:style-name="ta1"><table:table-column table:style-name="co5" table:default-cell-style-name="Default"/><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>CONTENIDO</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell/></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Revisión bibliográfica</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Datos son correctos. Hay que hacer una descripción eshaustiva de los datos, explicando, calidad, dimensiones, cantidad. Es conveniente complementarlo con una tabla.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>El modelo es correcto. Hay que justificar porque se ha elegido ese modelo/solución y no otra.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>La descripción matemática del objetivo y la forma de evaluarlo, se ajustan al objetivo conceptual.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Los experimentos son correctos</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Los resultados soportan las conclusiones</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Tema novedoso, interesante e importante.</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>Calidad de la Idea hay que justificarla respecto al estado del arte y las restricciones que tiene nuestro problema.</text:p></table:table-cell></table:table-row></table:table><table:table table:name="REFERENCIAS" table:style-name="ta1"><table:table-column table:style-name="co6" table:default-cell-style-name="Default"/><table:table-row table:style-name="ro1"><table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string"><text:p>REFERENCIAS</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell/></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>https://instituciones.sld.cu/cpicmmtz/redaccion-de-un-articulo-cientifico/</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>https://www.colegiomilitar.mil.ar/rediu/pdf/ReDiU_0924_art3-Texto_cientifico%28Azzollini_Nistal%29.pdf</text:p></table:table-cell></table:table-row><table:table-row table:style-name="ro1"><table:table-cell office:value-type="string" calcext:value-type="string"><text:p>http://www.guidelines.kaowarsom.be/evaluating_scientific_papers#:~:text=We%20list%20the%20most%20important,steps%20to%20attain%20his%20results%3F</text:p></table:table-cell></table:table-row></table:table><table:named-expressions/></office:spreadsheet></office:body></office:document-content>